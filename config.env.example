# config.env.example — Copy this file to config.env and fill in your values.
# config.env is gitignored and must never be committed.
#
# Usage:
#   cp config.env.example config.env
#   # edit config.env with your values
#   # then run scripts normally — they source config.env automatically

# Your domain (e.g. example.com). Subdomains nginx. and argo. will be used.
DOMAIN="example.com"

# Email for Let's Encrypt expiry notifications.
ACME_EMAIL="you@example.com"

# Your fork of this repo — ArgoCD watches it for GitOps sync.
REPO_URL="https://github.com/your-username/Challenge-Lab"
